# --- Server ---
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# --- Database (your local MariaDB / MySQL) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tutorx

# --- Auth ---
# Change this to a long random string before any real use.
JWT_SECRET=dev-only-change-me-to-something-long-and-random
JWT_EXPIRES_IN=7d

# --- Seed owner-admin account (created by `npm run db:setup`) ---
ADMIN_NAME=TutorX Admin
ADMIN_EMAIL=admin@tutorx.sg
ADMIN_PASSWORD=admin12345

# Where uploaded credential files are stored (relative to /server)
UPLOAD_DIR=uploads
